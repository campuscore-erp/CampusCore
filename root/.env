# ═══════════════════════════════════════════════════════════════════
#  CampusCore University ERP — Environment Configuration
# ═══════════════════════════════════════════════════════════════════

# ── DATABASE CONFIGURATION ──────────────────────────────────────────
# OPTION A: SQL Server (Windows Authentication — no username/password)
DB_SERVER=APPU\SQLEXPRESS
DB_NAME=UniversityERP
DB_USER=
DB_PASSWORD=

# For SQL Server with username/password, uncomment:
# DB_USER=your_username
# DB_PASSWORD=your_password

# Force a specific backend: 'mssql' or 'sqlite'
# Comment out DB_BACKEND to let the app auto-detect
# (auto-detect: tries MSSQL first, falls back to SQLite automatically)
DB_BACKEND=mssql

# OPTION B: SQLite (zero-config — no SQL Server needed)
# To use SQLite, comment out DB_BACKEND=mssql above, or set:
# DB_BACKEND=sqlite
# SQLITE_PATH=university_erp.db

# ── FLASK SECRET KEYS ───────────────────────────────────────────────
SECRET_KEY=9c585ff851b4a663824defa42c4a62107dd5b3900850d465c3ae4176e93c1c93
JWT_SECRET_KEY=6b43fe5f59dfd1dec6b335758541ba41664d95eed4c0387000c54c0cf932664a

# ── SERVER CONFIGURATION ────────────────────────────────────────────
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=True
